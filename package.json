{
    "name": "valyrian-edge",
    "version": "1.0.0",
    "description": "Autonomous AI Penetration Testing Platform for LLM-powered applications",
    "author": "Valyrian Security",
    "license": "AGPL-3.0",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "templates",
        "prompts",
        "configs",
        "registry.json",
        "action.yml"
    ],
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./sdk": {
            "import": "./dist/sdk/index.js",
            "types": "./dist/sdk/index.d.ts"
        },
        "./dashboard": {
            "import": "./dist/dashboard/index.js",
            "types": "./dist/dashboard/index.d.ts"
        },
        "./plugins": {
            "import": "./dist/plugins/index.js",
            "types": "./dist/plugins/index.d.ts"
        }
    },
    "bin": {
        "valyrian": "./dist/cli/index.js"
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsx watch src/cli/index.ts",
        "start": "node dist/cli/index.js",
        "start:worker": "node dist/orchestrator/worker.js",
        "valyrian": "tsx src/cli/index.ts",
        "test": "vitest",
        "test:coverage": "vitest --coverage",
        "test:ui": "vitest --ui",
        "lint": "eslint src --ext .ts",
        "lint:fix": "eslint src --ext .ts --fix",
        "format": "prettier --write \"src/**/*.ts\"",
        "format:check": "prettier --check \"src/**/*.ts\"",
        "typecheck": "tsc --noEmit",
        "clean": "rm -rf dist node_modules",
        "docker:build": "docker build -t valyrian-edge .",
        "docker:up": "docker-compose up -d",
        "docker:down": "docker-compose down",
        "docker:logs": "docker-compose logs -f",
        "temporal:start": "docker-compose up -d temporal postgresql temporal-ui",
        "temporal:stop": "docker-compose down temporal postgresql temporal-ui"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.27.0",
        "@langchain/anthropic": "^0.3.0",
        "@langchain/core": "^0.3.0",
        "@langchain/ollama": "^0.1.0",
        "@langchain/openai": "^0.3.0",
        "@temporalio/activity": "^1.11.0",
        "@temporalio/client": "^1.11.0",
        "@temporalio/common": "^1.11.0",
        "@temporalio/worker": "^1.11.0",
        "@temporalio/workflow": "^1.11.0",
        "chalk": "^5.3.0",
        "commander": "^12.0.0",
        "dotenv": "^16.4.0",
        "inquirer": "^9.2.0",
        "nanoid": "^5.0.0",
        "ora": "^8.0.0",
        "pino": "^9.0.0",
        "pino-pretty": "^11.0.0",
        "yaml": "^2.4.0",
        "zod": "^3.23.0"
    },
    "optionalDependencies": {
        "playwright": "^1.45.0"
    },
    "devDependencies": {
        "@types/inquirer": "^9.0.7",
        "@types/node": "^22.0.0",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "@vitest/coverage-v8": "^2.1.9",
        "@vitest/ui": "^2.0.0",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^9.0.0",
        "msw": "^2.12.9",
        "prettier": "^3.3.0",
        "tsx": "^4.16.0",
        "typescript": "^5.5.0",
        "vitest": "^2.1.9"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "keywords": [
        "security",
        "penetration-testing",
        "llm",
        "ai-security",
        "chatbot",
        "prompt-injection",
        "owasp",
        "vulnerability-scanner"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/valyrian-security/valyrian-edge.git"
    }
}
