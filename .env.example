# Valyrian Edge Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM CONFIGURATION
# =============================================================================

# LLM Provider: anthropic | openai | ollama
# Use "ollama" for local development without API keys
VALYRIAN_LLM_PROVIDER=anthropic

# Anthropic Claude API Key (used when VALYRIAN_LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (used when VALYRIAN_LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Ollama Configuration (used when VALYRIAN_LLM_PROVIDER=ollama)
# No API key required - runs locally
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest

# Model Selection (provider-specific defaults)
# Anthropic: claude-sonnet-4-20250514
# OpenAI: gpt-4o
# Ollama: llama3.2:latest, mistral:latest, etc.
VALYRIAN_LLM_MODEL=claude-sonnet-4-20250514
VALYRIAN_LLM_TEMPERATURE=0.7
VALYRIAN_LLM_MAX_TOKENS=4096

# =============================================================================
# TEMPORAL CONFIGURATION
# =============================================================================

# Temporal Server Address
TEMPORAL_ADDRESS=localhost:7233

# Temporal Namespace
TEMPORAL_NAMESPACE=valyrian-edge

# Temporal Task Queue
TEMPORAL_TASK_QUEUE=valyrian-pentest-queue

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL Connection (for Temporal and audit logs)
DATABASE_URL=postgresql://valyrian:valyrian_secure_password@localhost:5432/valyrian_edge

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Log Level: debug, info, warn, error
LOG_LEVEL=info

# Output Directory for Reports and Audit Logs
OUTPUT_DIR=./audit-logs

# Enable Color Output in CLI
FORCE_COLOR=1

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Rate Limiting (requests per minute per target)
RATE_LIMIT_RPM=30

# Request Timeout (seconds)
REQUEST_TIMEOUT_SECONDS=30

# Max Retries for Failed Requests
MAX_RETRIES=3

# =============================================================================
# BROWSER AUTOMATION (Playwright)
# =============================================================================

# Headless Mode (true for CI/CD, false for debugging)
BROWSER_HEADLESS=true

# Browser Type: chromium, firefox, webkit
BROWSER_TYPE=chromium

# Screenshot on Failure
SCREENSHOT_ON_FAILURE=true

# =============================================================================
# API SERVER (Optional)
# =============================================================================

# API Server Port
API_PORT=3000

# API Server Host
API_HOST=0.0.0.0

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
